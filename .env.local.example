# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Database (Prisma) ──────────────────────────────────────────────────────────
DATABASE_URL=              # Supabase pooled connection string
DIRECT_URL=                # Supabase direct connection (for migrations)

# ── Auth ──────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# ── Email ─────────────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ── Supabase SMTP via Resend ─────────────────────────────────────────────────
# Configure these in Supabase Dashboard → Authentication → SMTP Settings
# Host: smtp.resend.com | Port: 465 | User: resend | Password: RESEND_API_KEY
# Sender: LetSorted <hello@letsorted.co.uk>

# ── Payments ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=
CRON_SECRET=

# ── Analytics & Marketing ────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX          # Google Analytics (analytics.google.com)
NEXT_PUBLIC_FB_PIXEL_ID=XXXXXXXXXXXXXXXXX  # Facebook Pixel (business.facebook.com/events-manager)
NEXT_PUBLIC_CLARITY_ID=XXXXXXXXXX       # Microsoft Clarity (clarity.microsoft.com)
